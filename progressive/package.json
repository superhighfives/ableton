{
  "name": "progressive",
  "version": "1.0.0",
  "main": "dist/extension.js",
  "engines": {
    "node": ">=22.11.0"
  },
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && tsx build.ts --production",
    "build:dev": "tsc --noEmit && tsx build.ts",
    "start": "pnpm build:dev && extensions-cli run",
    "test": "tsx src/theory.test.ts",
    "package": "pnpm build && mkdir -p build && extensions-cli package -o build/progressive-${npm_package_version}.ablx"
  },
  "dependencies": {
    "@ableton-extensions/sdk": "file:../extensions-sdk-1.0.0-beta.0/ableton-extensions-sdk-1.0.0-beta.0.tgz"
  },
  "devDependencies": {
    "@ableton-extensions/cli": "file:../extensions-sdk-1.0.0-beta.0/ableton-extensions-cli-1.0.0-beta.0.tgz",
    "@types/node": "^24.1.0",
    "esbuild": "0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
